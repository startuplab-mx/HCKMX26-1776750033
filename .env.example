# CHIMALLI - Variables de entorno
# Copia este archivo como ".env" y rellena cada valor.
# NUNCA subas el .env real al repositorio.


# YouTube Data API v3
# Como obtenerla:
#   1. Ve a https://console.cloud.google.com/
#   2. Crea un proyecto (o selecciona uno existente)
#   3. Habilita "YouTube Data API v3" en APIs y servicios > Biblioteca
#   4. Ve a APIs y servicios > Credenciales > Crear credencial > Clave de API
#   5. (Opcional) Restringe la clave a la YouTube Data API v3
YOUTUBE_API_KEY=TU_CLAVE_AQUI


# Telegram API
# Como obtenerlos:
#   1. Ve a https://my.telegram.org (inicia sesion con tu numero de telefono)
#   2. Haz clic en "API development tools"
#   3. Crea una app (nombre y plataforma libres)
#   4. Copia el "App api_id" y el "App api_hash"
TELEGRAM_API_ID=TU_API_ID
TELEGRAM_API_HASH=TU_API_HASH


# MongoDB Atlas
# Como obtenerla:
#   1. Ve a https://cloud.mongodb.com/
#   2. Crea un cluster gratuito (M0) o selecciona uno existente
#   3. En "Database Access" crea un usuario con rol readWrite
#   4. En "Network Access" agrega tu IP (o 0.0.0.0/0 para desarrollo)
#   5. En el cluster haz clic en "Connect" > "Drivers" > copia el URI
#   6. Reemplaza <username> y <password> con los del paso 3
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?appName=Bronze


# OpenAI API
# Como obtenerla:
#   1. Ve a https://platform.openai.com/api-keys
#   2. Inicia sesion o crea una cuenta
#   3. Haz clic en "Create new secret key"
#   4. Copia la clave (solo se muestra una vez)
#   Nota: requiere creditos en https://platform.openai.com/settings/organization/billing
OPENAI_API_KEY=sk-proj-...
